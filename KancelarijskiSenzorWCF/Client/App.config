<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
	</startup>

	<appSettings>
		<add key="CsvPath" value="C:\SenzorData\AirPi Data - AirPi.csv" />
		<add key="LogPath" value="nevalidni_redovi.log" />
	</appSettings>

	<system.serviceModel>
		<bindings>
			<netTcpBinding>
				<binding name="SensorTcpBinding"
                         transferMode="Streamed"
                         maxReceivedMessageSize="2147483647"
                         sendTimeout="00:10:00"
                         receiveTimeout="00:10:00">
					<security mode="None" />
				</binding>
			</netTcpBinding>
		</bindings>

		<client>
			<endpoint address="net.tcp://localhost:4005/SensorService"
                      binding="netTcpBinding"
                      bindingConfiguration="SensorTcpBinding"
                      contract="Common.ISensorService"
                      name="SensorServiceEndpoint" />
		</client>
	</system.serviceModel>
</configuration>